# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- X / Twitter API (developer.x.com → your app → Keys and tokens) ---
# OAuth 2.0 (REQUIRED — the only auth X allows for reading bookmarks).
# Set up a "Web App" (confidential client) for a refresh token.
# Register this callback in the app: http://127.0.0.1:8675/callback
TWITTER_OAUTH2_CLIENT_ID=
TWITTER_OAUTH2_CLIENT_SECRET=

# --- LLM backend for generation (`tf generate`) ---
# DEFAULT: the Claude Code CLI (`claude`) — NO API KEY NEEDED. tf spawns `claude -p`
# as a subagent (uses your Claude Code auth; works headless on a server where claude
# is installed + logged in). To use a direct API instead, set TF_LLM_PROVIDER + a key:
# TF_LLM_PROVIDER=anthropic        # claude-code (default) | anthropic | openrouter | openai
# TF_LLM_MODEL=opus                # override the model (claude-code passes this to `claude --model`)
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# --- Tavily (timely topics + article enrichment) ---
# Free key at https://tavily.com
TAVILY_API_KEY=

# --- Notion (optional: tag notable pages as static grounding for generation) ---
# Create an internal integration at https://www.notion.so/my-integrations, then
# share the pages you want with it. Paste the integration secret here.
# NOTION_API_KEY=

# --- Slack (optional: push generated drafts) ---
# SLACK_WEBHOOK_URL=

# --- OAuth flow overrides (optional: cross-machine / Tailscale auth) ---
# OAUTH_REDIRECT_URI=http://127.0.0.1:8675/callback
# OAUTH_PORT=8675
# OAUTH_BIND_HOST=0.0.0.0
